generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum RoleName {
  FACULTY
  EMPLOYEE
  HOD
  COMMITTEE
  HR
  MANAGEMENT
  SUPER_ADMIN
}

enum AppraisalStatus {
  DRAFT
  SUBMITTED
  HOD_REVIEW
  ADMIN_REVIEW
  HR_FINALIZED
  COMMITTEE_REVIEW
  FULLY_APPROVED
  REJECTED
  SUPER_ADMIN_PENDING
  CLOSED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  departmentId  String?
  department    Department? @relation("DepartmentUsers", fields: [departmentId], references: [id])
  hodDepartment Department? @relation("DepartmentHod")
  roles         UserRole[]
  documents     Document[]
  refreshTokens RefreshToken[]
  loginAttempts LoginAttempt[]
  passwordResetTokens PasswordResetToken[]
  appraisals    Appraisal[]
  memoDeductions MemoDeduction[]
  committees    Committee[] @relation("CommitteeMembers")
  auditLogs     AuditLog[]
  publications  Publication[]
  patents       Patent[]
  consultancyGrants ConsultancyGrant[]
  facultyProfile FacultyProfile?
  failedLoginCount Int       @default(0)
  lockedUntil   DateTime?
  passwordChangedAt DateTime? @default(now())
  lastLoginAt   DateTime?
  mustChangePassword Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  @@index([departmentId])
  @@index([deletedAt])
  @@index([createdAt])
}

model FacultyProfile {
  userId             String   @id
  user               User     @relation(fields: [userId], references: [id])
  fatherName         String?
  dob                DateTime?
  dateOfJoining      DateTime?
  currentSalary      Float?
  lastIncrementDate  DateTime?
  panEncrypted       String?
  aadharEncrypted    String?
  tenthMarks         Float?
  twelfthMarks       Float?
  qualification      String?
  graduation         String?
  postGraduation     String?
  otherPgDegree      String?
  phdDegree          String?
  imageUrl           String?
  totalExperience    Float?
  designation        String?
  employeeCode       String?
  collegeName        String?
  profileRemarks     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Department {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String?
  hodId       String?  @unique
  hod         User?   @relation("DepartmentHod", fields: [hodId], references: [id])
  users       User[]  @relation("DepartmentUsers")
  placementStats PlacementStat[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([deletedAt])
}

model UserRole {
  id     String   @id @default(uuid())
  user   User     @relation(fields: [userId], references: [id])
  userId String
  role   RoleName
  createdAt DateTime @default(now())
  @@index([userId])
}

model Document {
  id              String   @id @default(uuid())
  owner           User     @relation(fields: [ownerId], references: [id])
  ownerId         String
  module          String
  fieldKey        String
  name            String
  originalName    String
  mime            String
  size            Int
  driveId         String?  // reference to Google Drive file id
  viewUrl         String?
  directUrl       String?
  folderId        String?
  storageProvider String   @default("google-drive")
  metadataJson    Json?
  uploadedAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@unique([ownerId, module, fieldKey])
  @@index([ownerId, module])
}

model RefreshToken {
  id            String   @id @default(uuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String
  tokenHash     String   @unique
  familyId      String
  jti           String   @unique
  revokedAt     DateTime?
  replacedById  String?
  userAgent     String?
  ipAddress     String?
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?
  expiresAt     DateTime

  @@index([userId, familyId])
}

model AppraisalCycle {
  id          String   @id @default(uuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  appraisals  Appraisal[]
  memoDeductions MemoDeduction[]
  placementStats PlacementStat[]

  @@index([isActive])
  @@index([isActive, startDate])
}

model Appraisal {
  id             String         @id @default(uuid())
  cycleId        String
  cycle          AppraisalCycle @relation(fields: [cycleId], references: [id])
  userId         String
  user           User           @relation(fields: [userId], references: [id])
  status         AppraisalStatus @default(DRAFT)
  submittedAt    DateTime?
  locked         Boolean         @default(false)
  finalScore     Float?
  finalPercent   Float?
  hodRemarks     String?
  adminRemark    String?
  committeeNotes String?
  superAdminApprovedPercent Float?
  superAdminRemark String?
  rejectedAt     DateTime?
  rejectedBy     String?
  rejectionReason String?
  items          AppraisalItem[]
  committeeAssignments CommitteeAssignment[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([cycleId])
  @@index([userId, cycleId])
  @@index([cycleId, status])
  @@index([status, submittedAt])
  @@index([submittedAt])
}

model AppraisalItem {
  id            String   @id @default(uuid())
  appraisal     Appraisal @relation(fields: [appraisalId], references: [id])
  appraisalId   String
  key           String   // e.g., "academics_average", "fdf_stp"
  points        Int
  weight        Float
  notes         String?
  createdAt     DateTime @default(now())

  @@index([appraisalId])
}

model ScoringConfig {
  id          String   @id @default(uuid())
  key         String   @unique
  schemaJson  String   // JSON description of brackets and points
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MemoDeduction {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  cycleId   String
  cycle     AppraisalCycle @relation(fields: [cycleId], references: [id])
  count     Int
  pointsDeducted Int
  createdAt DateTime @default(now())

  @@index([userId, cycleId])
}

model LoginAttempt {
  id          String   @id @default(uuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  email       String
  ipAddress   String?
  userAgent   String?
  success     Boolean  @default(false)
  reason      String?
  createdAt   DateTime @default(now())

  @@index([email, createdAt])
  @@index([userId, createdAt])
}

model PasswordResetToken {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  tokenHash   String   @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
}

model Committee {
  id        String   @id @default(uuid())
  name      String
  members   User[]   @relation("CommitteeMembers")
  assignments CommitteeAssignment[]
}

model CommitteeAssignment {
  id          String   @id @default(uuid())
  committeeId String
  committee   Committee @relation(fields: [committeeId], references: [id])
  appraisalId String
  appraisal   Appraisal @relation(fields: [appraisalId], references: [id])
  assignedAt  DateTime @default(now())

  @@index([appraisalId])
  @@index([committeeId])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String
  resource   String
  resourceId String?
  meta       String?
  createdAt  DateTime @default(now())
  immutable  Boolean  @default(true)

  @@index([actorId, createdAt])
  @@index([resource, resourceId])
  @@index([createdAt])
}

model Publication {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  title      String
  journal    String?
  scopus     Boolean  @default(false)
  impactFactor Float?
  createdAt  DateTime @default(now())

  @@index([userId])
}

model Patent {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  type       String
  granted    Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([userId])
}

model ConsultancyGrant {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  amount     Float
  createdAt  DateTime @default(now())

  @@index([userId])
}

model PlacementStat {
  id         String   @id @default(uuid())
  departmentId String
  department Department @relation(fields: [departmentId], references: [id])
  cycleId    String
  cycle      AppraisalCycle @relation(fields: [cycleId], references: [id])
  percent    Float
  createdAt  DateTime @default(now())

  @@index([departmentId])
  @@index([cycleId])
  @@index([departmentId, cycleId])
}
